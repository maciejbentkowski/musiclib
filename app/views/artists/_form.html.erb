<%= form_with(model: @artist) do |form| %>
    <div class ="field mt-1 mx-1">
        <%= form.label :artist_name, class:"label" %>
        <div class = "control">
        <%= form.text_field :artist_name, class:"input" %>
        </div>
    </div>
        <div class="control mt-1 mx-1">
        <%= form.submit class:"button is-primary" %>
        </div>
  <% end %>

<%= link_to "Back", artists_path, class:"button is-link mt-2 mx-1" %>