<h1>Add Disc</h1>
</br>

<%= form_for [@artist, @disc] do |form| %>
    <div class="field mx-1 mt-2">
        <%= form.label :disc_name, class:"label"%>
        <div class = "control">
        <%= form.text_field :disc_name, class:"input"%>
        </div>
        <%= form.label :music_type, class:"label"%>
        <div class = "control">
        <%= form.text_field :music_type, class:"input"%>
        </div>
        <%= form.label :image, class:"label"%>
        <div class = "control">
        <%= form.file_field :image, class:"input"%>
        </div>
    </div>
    <div class="control mx-1 mt-2">
        <%= form.submit class:"button is-primary"%>
    </div>
  <% end %>
  </br>